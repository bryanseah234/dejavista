# DejaView Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# FRONTEND (Chrome Extension) - Required
# ============================================
# Get from: Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Your deployed Vercel API URL (after deployment)
VITE_VERCEL_API_URL=https://your-project.vercel.app

# ============================================
# BACKEND (Vercel Functions) - Required
# ============================================
# Get from: Supabase Dashboard > Settings > API > service_role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Get from: Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Get from: Google Cloud Console > Project Settings
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# Optional: Vertex AI location (default: us-central1)
VERTEX_AI_LOCATION=us-central1
